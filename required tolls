#!/usr/bin/env bash

# Hunt3r System Dependencies Installer
echo "[*] Installing system dependencies for Hunt3r..."

# Ensure system package lists are up to date
sudo apt-get update

# Install Core Tools available via APT
sudo apt-get install -y nmap sqlmap dirsearch metasploit-framework git python3 python3-pip

# Install Sublist3r in the User's Home Directory (as expected by Hunt3r)
if [ ! -d "$HOME/Sublist3r" ]; then
    echo "[*] Cloning Sublist3r to home directory..."
    git clone https://github.com "$HOME/Sublist3r"
    echo "[*] Installing Sublist3r Python dependencies..."
    pip3 install -r "$HOME/Sublist3r/requirements.txt"
else
    echo "[+] Sublist3r already installed."
fi

# Ensure Hunt3r itself is executable
chmod +x Hunt3r.sh

echo "[+] Installation complete! You can now run sudo ./Hunt3r.sh"
